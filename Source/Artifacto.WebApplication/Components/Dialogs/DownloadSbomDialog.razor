@namespace Artifacto.WebApplication.Components.Dialogs
@using System.ComponentModel.DataAnnotations

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="Icons.Material.Filled.Download" Class="mr-3 mb-n1" />
            Download SBOM
        </MudText>
    </TitleContent>
    <DialogContent>
        <EditForm @ref="_form" Model="@_model" OnValidSubmit="@OnValidSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <MudStack Spacing="3">
                <MudTextField Value="@ArtifactVersion"
                              Label="Artifact Version"
                              Variant="Variant.Outlined"
                              ReadOnly="true" />

                <MudSelect T="string"
                           @bind-Value="_model.Format"
                           Label="Format"
                           Variant="Variant.Outlined"
                           Required="true">
                    <MudSelectItem Value="@("json")">JSON</MudSelectItem>
                    <MudSelectItem Value="@("xml")">XML</MudSelectItem>
                </MudSelect>

                <MudSelect T="string"
                           @bind-Value="_model.SpecVersion"
                           Label="CycloneDX Version"
                           Variant="Variant.Outlined"
                           Required="true">
                    <MudSelectItem Value="@("1.3")">1.3</MudSelectItem>
                    <MudSelectItem Value="@("1.4")">1.4</MudSelectItem>
                    <MudSelectItem Value="@("1.5")">1.5</MudSelectItem>
                    <MudSelectItem Value="@("1.6")">1.6</MudSelectItem>
                    <MudSelectItem Value="@("1.7")">1.7</MudSelectItem>
                </MudSelect>
            </MudStack>
        </EditForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="HandleSubmit">
            Download
        </MudButton>
    </DialogActions>
</MudDialog>